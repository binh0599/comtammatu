{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/process-deletions",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/upgrade-tiers",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/inventory-alerts",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/expire-payments",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/expire-points",
      "schedule": "0 2 * * *"
    }
  ]
}
